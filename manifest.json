{
  "manifest_version": 3,
  "name": "EvilBot Next",
  "version": "1.0.0",
  "description": "Next generation modular bot for Stake / Stake.us / Primedice",

  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": [
    "https://stake.com/*",
    "https://stake.us/*",
    "https://primedice.com/*"
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://stake.com/*",
        "https://stake.us/*",
        "https://primedice.com/*"
      ],
      "js": ["src/content/inject.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/ui/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
